# Copie pra .env e preencha com valores reais — nunca commitar o .env em si.

# Chave usada pelo Flask pra assinar sessão/cookies. Gere um valor
# aleatório longo, diferente por ambiente (dev/produção).
SECRET_KEY=

# Chave usada pra assinar os tokens JWT (access/refresh). Também deve
# ser um valor aleatório longo e diferente de SECRET_KEY.
JWT_SECRET_KEY=

# String de conexão do Postgres, no formato que o SQLAlchemy/psycopg 3
# esperam: postgresql+psycopg://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=

# "true" liga o modo debug do Flask (autoreload, stack trace detalhado
# nas respostas de erro). Nunca "true" em produção.
FLASK_DEBUG=false

# Duração do access token, em segundos. Padrão no código: 900 (15min).
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=900

# Duração do refresh token, em segundos. Padrão no código: 2592000 (30 dias).
JWT_REFRESH_TOKEN_EXPIRES_SECONDS=2592000

# Origens de navegador permitidas por CORS, separadas por vírgula (ex:
# https://app.exemplo.com,https://outro.exemplo.com). Vazio nega CORS
# pra qualquer origem por padrão.
#
# NOTA (2026-07-08): a restrição de CORS está temporariamente desativada
# no código (app/__init__.py usa CORS(app) sem restrição) pra permitir
# testar o app como PWA — ver docs/v2-compartilhamento-e-seguranca.md.
# Essa variável não tem efeito enquanto isso não for revertido.
CORS_ALLOWED_ORIGINS=
